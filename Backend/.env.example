# ================================
# SERVER
# ================================
NODE_ENV=development
PORT=5000

# ================================
# DATABASE
# ================================
# MongoDB Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/grocery-store
# Local:         mongodb://localhost:27017/grocery-store
MONGODB_URI=mongodb://localhost:27017/grocery-store

# ================================
# JWT
# ================================
JWT_ACCESS_SECRET=your_super_secret_access_key_change_this_in_production_min_32_chars
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ================================
# IMAGEKIT
# ================================
IMAGEKIT_PUBLIC_KEY=your_imagekit_public_key
IMAGEKIT_PRIVATE_KEY=your_imagekit_private_key
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# ================================
# CORS
# ================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ================================
# ADMIN SEED (first-run admin account)
# ================================
ADMIN_EMAIL=admin@shop.com
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=Store Admin
